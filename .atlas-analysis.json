  "keyFeatures": [
    "Bulk media download (images & videos) from 8 social platforms",
    "Browser automation with Puppeteer Stealth for anti-bot bypass",
    "Session persistence via browser profile userDataDir (OnlyFans)",
    "Concurrent downloads with a configurable pool via mapLimit utility",
    "Network request interception for CSRF tokens and user metadata",
    "Stagnation detection to prevent infinite scroll loops",
    "Referer spoofing and cookie injection per platform",
    "Automatic filename sanitization for cross-platform compatibility"
  ],
  "publicApiSurface": [
    "GET /deviantart/get-all-media?username=&limit=",
    "GET /onlyfans/get-all-media?username=&limit=",
    "GET /pixiv/get-all-media?userId=&limit=&mediaType=",
    "GET /x/get-all-media?username=&limit=&method=",
    "GET /threads/get-all-media?username=&limit=",
    "GET /tiktok/get-all-media?username=&limit=",
    "GET /pinterest/get-all-media?username=&limit=",
    "GET /instagram/get-all-media?username=&limit="
  ]
